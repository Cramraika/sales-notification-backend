# Sales Notification Backend
PORT=3000
NODE_ENV=development

# Required
EXTENSION_ID=          # Chrome Extension ID
WEBHOOK_TOKEN=         # Token for LeadSquared webhook authentication
JWT_SECRET=            # JWT signing secret for OTP auth
SENDGRID_API_KEY=      # SendGrid API key for OTP emails

# n8n Workflow Automation
N8N_WEBHOOK_URL=https://n8n.chinmayramraika.in
N8N_API_KEY=your-project-specific-n8n-api-key
